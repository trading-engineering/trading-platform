{
  "name": "TradingChassis Core Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspaces/core",
  "remoteUser": "root",
  "runArgs": ["--security-opt=label=disable"],
  "containerEnv": {
    "SHELL": "/bin/bash"
  },

  "postCreateCommand": "pip install -e .[dev]"

}
